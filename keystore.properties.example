# Copy to keystore.properties (gitignored) and fill in before signed releases.
# Do not regenerate upload-keystore.jks once Play Console registration is approved.
# Back up upload-keystore.jks and keystore.properties together.
#
# Generate a new upload keystore (one-time):
#   keytool -genkeypair -v -keystore upload-keystore.jks -alias upload -keyalg RSA -keysize 2048 -validity 10000
#
# GitHub Actions secrets (Settings -> Secrets -> Actions):
#   UPLOAD_KEYSTORE_BASE64  - base64 of upload-keystore.jks
#   UPLOAD_KEYSTORE_PASSWORD
#   UPLOAD_KEY_ALIAS        - usually "upload"
#   UPLOAD_KEY_PASSWORD
#
# Play Console: enroll in Play App Signing and register this upload key.
# Google holds the app signing key; users get APKs/AABs re-signed by Google.

storeFile=upload-keystore.jks
storePassword=change-me
keyAlias=upload
keyPassword=change-me
